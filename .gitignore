data/**/*
!data/README.md
!data/README_zh.md
!data/subject_data_inventory.csv
!data/Brodmann_ROI.csv

# --- manuscript (local paper workspace) ---
manuscript/

# --- Third-party toolboxes (install locally; see docs/install.md) ---
code/utils/Homer3-*/
code/utils/fieldtrip-*/

# --- Editor / Python cache ---
__pycache__/
*.pyc
.DS_Store
.cursor/
.vscode/

# --- run_logs ---
logs/

# ---------------------------------------------------------------------------
